@model SereneMovieTutorial.Reports.CustomerSelectionViewModel
@{
    ViewBag.Title = "Select Customer";

}

<h2>Select Customer</h2>

@using (Html.BeginForm("GetCustId", "CustomerVehicleReport", FormMethod.Get))
{

    <div>
        <label>Customer Code</label><br />

        @Html.DropDownList(
            "id",
            new SelectList(Model.Customers, "Id", "Code"),
            "--Select Your ID--",
            new { @class = "form-control" }
        )
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        View Report
    </button>
}



@{
    ViewBag.Title = "Index";
}
<h2>Customer Vehicle Report</h2>
<hr />
@if (Model == null)
{
    <p>No records found.</p>
}
else
{
    <!-- 🔹 Customer Details -->
    <fieldset style="margin-bottom:20px;">
        <legend><b>Customer Details</b></legend>

        <table>
            <tr>
                <td><b>Customer Code:</b></td>
                <td>@Model.Vehicles.First().CustomerCode</td>

                <td><b>Name:</b></td>
                <td>@Model.Vehicles.First().FullName</td>
            </tr>
            <tr>
                <td><b>Mobile:</b></td>
                <td>@Model.Vehicles.First().MobileNumber</td>

                <td><b>Email:</b></td>
                <td>@Model.Vehicles.First().Email</td>
            </tr>
            <tr>
                <td><b>Address:</b></td>
                <td colspan="3">
                    @Model.Vehicles.First().AddressLine1,
                    @Model.Vehicles.First().City,
                    @Model.Vehicles.First().State -
                    @Model.Vehicles.First().PinCode
                </td>
            </tr>
            <tr>
                <td><b>DOB:</b></td>
                <td>
                    @(Model.Vehicles.First().DateOfBirth != null
                        ? Model.Vehicles.First().DateOfBirth.Value.ToString("dd-MMM-yyyy")
                        : "N/A")
                </td>


                <td><b>Status:</b></td>
                <td>@(Model.Vehicles.First().IsActive ? "Active" : "Inactive")</td>
            </tr>
        </table>
    </fieldset>

    <!-- 🔹 Vehicle Details -->
    <fieldset>
        <legend><b>Vehicle Details</b></legend>

        <table border="1" cellpadding="5" cellspacing="0" width="100%">
            <tr style="background:#f2f2f2;">
                <th>Vehicle No</th>
                <th>Type</th>
                <th>Brand</th>
                <th>Model</th>
                <th>Year</th>

                <th>Color</th>
                <th>Seats</th>
                <th>EngineNumber</th>
                <th>ChassisNumber</th>
                <th>Insurance Expiry</th>
                <th>Fuel Type</th>
                <th>Status</th>
            </tr>

            @foreach (var item in Model.Vehicles)
            {
                <tr>
                    <td>@item.VehicleNumber</td>
                    <td>
                        @(item.VehicleType == 1
                        ?"Truck"
                        :item.VehicleType == 2
                        ?"Bus"
                        :"Car")
                    </td>
                    <td>@item.Brand</td>
                    <td>@item.Model</td>
                    <td>@item.ManufacturingYear</td>

                    <td>@item.Color</td>
                    <td>@item.SeatingCapacity</td>
                    <td>@item.EngineNumber</td>
                    <td>@item.ChassisNumber</td>
                    <td>
                        @(item.InsuranceExpiryDate != null
                    ? item.InsuranceExpiryDate.Value.ToString("dd-MMM-yyyy")
                    : "N/A")
                    </td>
                    <td>
                        @(item.FuelType == 1
                        ?"Diesel"
                        :item.FuelType ==2
                        ?"Petrol"
                        :"EV"
                    )
                    </td>
                    <td>
                        @(item.VehicleIsActive == true
                              ? "Active"
                              : item.VehicleIsActive == false
                              ? "Inactive"
                              : "N/A")
                    </td>
                </tr>
            }
        </table>
    </fieldset>
}
<br />
<hr />


<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

<button onclick="exportToExcel()">Convert to Excel</button>

<script>
    // Serialize your model into JSON safely
    var data = @Html.Raw(Json.Encode(Model.Vehicles));

    function exportToExcel() {
        // Convert JSON to worksheet
        var ws = XLSX.utils.json_to_sheet(data);
        var wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Customers");

        // Trigger download
        XLSX.writeFile(wb, "CustomerReport.xlsx");
    }
</script>

<button onclick="exportToPdf()">Convert to PDF</button>

<script>
    // ✅ Helper to convert ASP.NET JSON date into dd-MMM-yyyy
    function formatDate(msDate) {
        if (!msDate) return "";
        var match = /\/Date\((\d+)\)\//.exec(msDate);
        if (!match) return msDate; // if it's already a string
        var timestamp = parseInt(match[1]);
        var date = new Date(timestamp);
        return date.toLocaleDateString("en-GB", { day: '2-digit', month: 'short', year: 'numeric' });
    }

    // Inject your model data
    var customers = @Html.Raw(Json.Encode(Model.Vehicles));
    var vehicles = @Html.Raw(Json.Encode(Model.Vehicles));

    function exportToPdf() {
        const doc = new window.jspdf.jsPDF();

        doc.setFontSize(14);
        doc.text("Customer Vehicle Report", 10, 10);

        // --- Customers Table ---
        const customerHeaders = [
            "FullName", "MobileNumber", "Email",
            "AddressLine1", "City", "State", "PinCode", "IdentityNumber",
             "IsActive", "CreatedDate"
        ];

        doc.autoTable({
            head: [customerHeaders],
            body: customers.map(c => customerHeaders.map(h => {
                if (h === "DateOfBirth" || h === "CreatedDate") {
                    return formatDate(c[h]);
                }
                return c[h];
            })),
            startY: 20,
            styles: { fontSize: 6 }
        });

        // --- Vehicles Table ---
        const vehicleHeaders = [
            "VehicleId", "VehicleNumber", "VehicleType", "Brand", "Model",
            "ManufacturingYear", "SeatingCapacity", "FuelType", "EngineNumber",
            "ChassisNumber", "Color", "InsuranceExpiryDate", "VehicleIsActive", "VehicleCreatedDate"
        ];

        doc.autoTable({
            head: [vehicleHeaders],
            body: vehicles.map(v => vehicleHeaders.map(h => {
                if (h === "InsuranceExpiryDate" || h === "VehicleCreatedDate") {
                    return formatDate(v[h]);
                }
                return v[h];
            })),
            startY: doc.lastAutoTable.finalY + 10,
            styles: { fontSize: 6 }
        });

        doc.save("CustomerVehicleReport.pdf");
    }
</script>
