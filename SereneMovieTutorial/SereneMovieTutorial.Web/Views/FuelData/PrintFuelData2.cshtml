@model SereneMovieTutorial.FuelManagement.Entities.FuelDataRow

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>PrintFuelData</title>

    <!-- Bootstrap 3 CSS -->
    <link rel="stylesheet" href="~/Content/bootstrap.min.css" />

    <style>
        /*.sign {
            height: 120px;
        }*/

        /* RECEIVER */

        /*.receiver-container {
            width: 120px;
            float: right;
            text-align: center;
        }

        .receiver-box {
            width: 80px;
            height: 80px;
            border: 1px solid black;
            margin: auto;
        }

        .receiver-text {
            margin-top: 6px;
            font-weight: bold;
        }*/
        /* PRINT: only show the visible voucher/table */
        @@media print {
    body * {
        visibility: hidden;
    }

    .print-section {
        display: none !important; /* hide all by default */
    }

    .print-section:target,
    .print-section.active {
        display: block !important;
        visibility: visible;
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
    }

    .print-section:target *,
    .print-section.active * {
        visibility: visible;
    }
}

    </style>
</head>

<body class="container">

    <!-- Action Buttons -->
    <div class="panel panel-default">
        <div class="panel-heading">
            <h3>Select Voucher to Print</h3>
        </div>
        <div class="panel-body">
            <button class="btn btn-primary" onclick="showOriginal()">DA Voucher</button>
            <button class="btn btn-success" onclick="showFinance()">Finance</button>
            <button class="btn btn-info" onclick="showTable()">Table 3</button>
        </div>
    </div>

    <!-- PRINT AREA -->
    <div id="printArea">

        <!-- ORIGINAL VOUCHER -->
        <div id="originalVoucher" class="print-section panel panel-default" style="display:none;">
            <!-- Header -->
            <div class="panel-heading text-center">
                <h2 class="panel-title">SHREE CHADDA ROADLINES</h2>
                <small>Near M.I.D.C Ghugus Road, Khutala, Chandrapur - 442406 (M.S.)</small>
            </div>

            <!-- Body -->
            <div class="panel-body">
                <h4 class="text-center text-uppercase">DA Voucher</h4>

                <!-- Voucher Table -->
                <table class="table table-bordered">
                    <tr>
                        <td><strong>Voucher Ref No</strong></td>
                        <td>@Model.InvoiceNo</td>
                        <td><strong>Date</strong></td>
                        <td>@Model.InvoiceDate</td>
                    </tr>
                    <tr>
                        <td><strong>Truck No</strong></td>
                        <td>@Model.TankerNo</td>
                        <td><strong>Driver Name</strong></td>
                        <td>@Model.RateLtr</td>
                    </tr>
                    <tr>
                        <td><strong>EGP No</strong></td>
                        <td>@Model.PartyId</td>
                        <td><strong>Qty</strong></td>
                        <td>@Model.QtyKl</td>
                    </tr>
                    <tr>
                        <td><strong>Rate</strong></td>
                        <td>@Model.RateKl</td>
                        <td><strong>Amount</strong></td>
                        <td>@Model.BasicAmount</td>
                    </tr>
                    <tr class="sign">

                        <td colspan="3">

                            <br><br><br>

                            <b>Cashier</b>

                        </td>

                        <td colspan="2">

                            <div class="receiver-container">

                                <div class="receiver-box"></div>

                                <div class="receiver-text">
                                    Receiver
                                </div>

                            </div>

                        </td>

                    </tr>
                </table>
            </div>
        </div>


        <!-- FINANCE VOUCHER -->
        <div id="financeVoucher" class="print-section panel panel-default" style="display:none;">
            <div class="panel-heading text-center">
                <h4>FINANCE DETAILS</h4>
            </div>
            <div class="panel-body">
                <table class="table table-bordered">
                    <tr>
                        <td><b>Total Amount</b></td>
                        <td>@Model.BasicAmount</td>
                    </tr>
                    <tr>
                        <td><b>TDS %</b></td>
                        <td>24%</td>
                    </tr>
                    <tr>
                        <td><b>TDS Amount</b></td>
                        <td>XXXX</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- TABLE 3 -->
        <div id="tableVoucher" class="print-section panel panel-default" style="display:none;">
            <div class="panel-heading text-center">
                <h4>TABLE 3</h4>
            </div>
            <div class="panel-body">
                <table class="table table-striped table-bordered">
                    <tr>
                        <td>Sample Data 1</td>
                        <td>Value 1</td>
                    </tr>
                    <tr>
                        <td>Sample Data 2</td>
                        <td>Value 2</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- PRINT BUTTON -->
    <button id="printBtn" class="btn btn-danger" style="display:none;" onclick="finalPrint()">
        Print Now
    </button>

    <!-- SCRIPT -->
    <script>
        function showOriginal() {
            document.getElementById("originalVoucher").style.display = "block";
            document.getElementById("originalVoucher").classList.add("active");

            document.getElementById("financeVoucher").style.display = "none";
            document.getElementById("financeVoucher").classList.remove("active");

            document.getElementById("tableVoucher").style.display = "none";
            document.getElementById("tableVoucher").classList.remove("active");

            document.getElementById("printBtn").style.display = "inline-block";
        }

        function showFinance() {
            document.getElementById("financeVoucher").style.display = "block";
            document.getElementById("financeVoucher").classList.add("active");

            document.getElementById("originalVoucher").style.display = "none";
            document.getElementById("originalVoucher").classList.remove("active");

            document.getElementById("tableVoucher").style.display = "none";
            document.getElementById("tableVoucher").classList.remove("active");

            document.getElementById("printBtn").style.display = "inline-block";
        }

        function showTable() {
            document.getElementById("tableVoucher").style.display = "block";
            document.getElementById("tableVoucher").classList.add("active");

            document.getElementById("originalVoucher").style.display = "none";
            document.getElementById("originalVoucher").classList.remove("active");

            document.getElementById("financeVoucher").style.display = "none";
            document.getElementById("financeVoucher").classList.remove("active");

            document.getElementById("printBtn").style.display = "inline-block";
        }


        function finalPrint() {
            window.print();
        }
    </script>
</body>
</html>
