{
  "compileOnSave": true,
  "compilerOptions": {
    //"esModuleInterop": true,
    //"allowSyntheticDefaultImports": true,
    "preserveConstEnums": true,
    "experimentalDecorators": true,
    "declaration": true,
    "emitBOM": true,
    "noEmitHelpers": true,
    "sourceMap": true,
    "outFile": "Scripts/site/SereneMovieTutorial.Web.js",
    "target": "es5",
    "module": "system",
    "skipLibCheck": true,
    "types": [ "jquery" ],
    "typeRoots": [
      "./node_modules/@types/"
    ]
  },
  "include": [
    "./Imports/",
    "./Modules/",
    "./Scripts/typings/",
    "./Serenity.CoreLib/"
  ],
  "exclude": [
    "node_modules"
  ]
}