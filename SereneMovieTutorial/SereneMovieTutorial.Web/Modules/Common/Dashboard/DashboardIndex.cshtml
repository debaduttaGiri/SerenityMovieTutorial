        function hmColor(val, min, max, hue) {
            const t = (val - min) / (max - min || 1);
            const alpha = .15 + t * .55;
            return `background:hsla(${hue},80%,55%,${alpha});color:${t > .5 ? '#e8edf5' : '#6b7a96'}`;
        }

