        $.get('/Dashboard/GetMineHeatmap', function (data) {

            const hm = document.getElementById('heatmap');

            if (!hm) {
                console.error("heatmap div not found");
                return;
            }

            if (!data || !data.length) {
                hm.innerHTML = '<div style="color:gray">No data</div>';
                return;
            }

            const headers = ['Margin%', 'Util%', 'Trips(K)', '₹/Trip'];
            const hues = [160, 210, 45, 280];

            let html = `
                <div class="heatmap-grid">
                <div class="hm-header"></div>
                ${headers.map(h => `<div class="hm-header">${h}</div>`).join('')}
                `;

            data.forEach(d => {

                const vals = [
                    Number(d.margin),
                    Number(d.util),
                    Number(d.trips) / 1000,   // convert to K
                    Number(d.rate)
                ];

                const ranges = [
                    [6, 32],
                    [47, 100],
                    [2, 18.3],
                    [4550, 40000]
                ];

                html += `<div class="hm-label">${d.label}</div>`;

                vals.forEach((v, i) => {

                    const style = hmColor(v, ranges[i][0], ranges[i][1], hues[i]);

                    html += `<div class="hm-cell" style="${style}">
                    ${i === 3
                            ? '₹' + Math.round(v / 1000) + 'K'
                            : v.toFixed(1) + (i < 2 ? '%' : 'K')}
                </div>`;
                });

            });

            html += '</div>';

            hm.innerHTML = html;

        });
